{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/downloads/MedX-Setup-0.2.0.zip",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/zip"
          },
          {
            "key": "Content-Disposition",
            "value": "attachment; filename=\"MedX-Setup-0.2.0.zip\""
          }
        ]
      }
    ]
  }
}
